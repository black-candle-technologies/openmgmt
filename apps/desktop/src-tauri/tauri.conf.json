{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenMgmt",
  "version": "0.1.0",
  "identifier": "com.openmgmt.desktop",
  "build": {
    "beforeDevCommand": {
      "script": "trunk serve --address 127.0.0.1 --port 1420",
      "cwd": "../ui",
      "wait": false
    },
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": {
      "script": "trunk build --release",
      "cwd": "../ui"
    },
    "frontendDist": "../ui/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "OpenMgmt",
        "width": 1440,
        "height": 920,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": false
  }
}
